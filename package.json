{
  "name": "synapse",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "SYNAPSE — mobile idle/incremental game where the player evolves a mind from a single neuron to cosmic superintelligence.",
  "scripts": {
    "dev": "npm run build:tokens && vite",
    "build": "npm run build:tokens && tsc -b && vite build",
    "preview": "vite preview",
    "build:tokens": "tsx scripts/generate-tailwind-theme.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "tsx scripts/perf-spike.ts",
    "test:perf:mi-a3": "tsx scripts/perf-spike-mi-a3.ts",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "check-invention": "bash scripts/check-invention.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor-community/admob": "^6.2.0",
    "@capacitor-firebase/analytics": "^6.3.1",
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.1.0",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/preferences": "^6.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@revenuecat/purchases-capacitor": "^9.2.2",
    "@types/howler": "^2.2.12",
    "firebase": "^11.10.0",
    "howler": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/browser": "^3.2.4",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "fast-check": "^4.7.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "vitest": "^3.0.0"
  }
}
