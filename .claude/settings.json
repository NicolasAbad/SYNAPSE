{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(npm publish*)"
    ],
    "ask": [
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(npx cap*)",
      "Write(docs/archive/**)"
    ]
  }
}