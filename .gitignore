# ═══════════════════════════════════════════════════════════════════
# SYNAPSE .gitignore
# ═══════════════════════════════════════════════════════════════════

# Dependencies
node_modules/
package-lock.json
# NOTE: keep yarn.lock / pnpm-lock.yaml IF you use those package managers
# (committing lockfile is standard practice). For npm, package-lock.json
# is typically committed — if you use npm, remove that line above.

# Build artifacts
dist/
build/
out/
.next/
.vite/
*.tsbuildinfo

# Native build outputs (Capacitor)
ios/App/build/
ios/App/Pods/
ios/DerivedData/
android/app/build/
android/.gradle/
android/build/
android/local.properties
android/app/debug/
android/app/release/

# Test coverage / reports
coverage/
.nyc_output/
test-results/
playwright-report/

# IDE / OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# VS Code — keep .vscode/ gitignored, but add exceptions for shared config
.vscode/*
!.vscode/settings.json.example
!.vscode/extensions.json

# JetBrains
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
logs/

# Environment files (SECRETS — never commit)
.env
.env.local
.env.*.local
.env.production
.env.development

# Firebase secrets
.firebase/
firebase-debug.log
google-services.json
GoogleService-Info.plist
serviceAccountKey.json

# Capacitor
capacitor.config.json.bak

# Game simulation outputs
sim/output/
sim/results/
*.csv

# Claude Code transcripts (if any are saved locally)
.claude/transcripts/
.claude/cache/

# macOS
.AppleDouble
.LSOverride

# Editor artifacts
*.orig
*.rej
