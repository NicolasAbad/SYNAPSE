# ═══════════════════════════════════════════════════════════════════
# SYNAPSE .gitignore
# ═══════════════════════════════════════════════════════════════════

# Dependencies
node_modules/

# Build artifacts
dist/
build/
out/
.next/
.vite/
*.tsbuildinfo

# Native build outputs (Capacitor)
ios/App/build/
ios/App/Pods/
ios/DerivedData/
android/app/build/
android/.gradle/
android/build/
android/local.properties
android/app/debug/
android/app/release/

# Test coverage / reports
coverage/
.nyc_output/
test-results/
playwright-report/

# Smoke playtest harness outputs (scripts/smoke-playtest*.mjs)
.playtest-screens/
.playtest-screens-mi-a3/
.playtest-screens-mi-a3-deep/
.playtest-screens-mi-a3-verify/
.playtest-report.json
.playtest-report-mi-a3.json
.playtest-report-mi-a3-deep.json

# IDE / OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# VS Code — keep .vscode/ gitignored, but add exceptions for shared config
.vscode/*
!.vscode/settings.json.example
!.vscode/extensions.json

# JetBrains
.idea/

# Logs
*.log
*.logcat
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
logs/

# Environment files (SECRETS — never commit)
.env
.env.local
.env.*.local
.env.production
.env.development

# Firebase secrets
.firebase/
firebase-debug.log
google-services.json
GoogleService-Info.plist
serviceAccountKey.json

# Capacitor
capacitor.config.json.bak

# Game simulation outputs
sim/output/
sim/results/
*.csv

# Claude Code transcripts (if any are saved locally)
.claude/transcripts/
.claude/cache/

# macOS
.AppleDouble
.LSOverride

# Editor artifacts
*.orig
*.rej

# Auto-generated Tailwind theme (from tokens.ts)
styles/_theme.generated.css
