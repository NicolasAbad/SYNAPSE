VITE_ADMOB_REWARDED_PIGGY_REFILL_IOS=ca-app-pub-3940256099942544/1712485313
VITE_ADMOB_REWARDED_STREAK_SAVE_IOS=ca-app-pub-3940256099942544/1712485313

# Firebase (Sprint 10 — fill after creating Firebase project)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
