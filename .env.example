# ═══════════════════════════════════════════════════════════════
# SYNAPSE Environment Variables (template — copy to .env.local)
# Do NOT commit .env.local (already in .gitignore)
# ═══════════════════════════════════════════════════════════════

# RevenueCat (Sprint 9a)
VITE_REVENUECAT_IOS_KEY=appl_xxxxx
VITE_REVENUECAT_ANDROID_KEY=goog_xxxxx

# AdMob — TEST IDs shown (replace with production IDs in release build only)
VITE_ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511
VITE_ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713

# AdMob Rewarded Ad Units — per-platform (AdMob assigns ad unit IDs per app,
# and our Android + iOS apps are distinct AdMob entries). TEST ID shown is
# Google's canonical rewarded-video test placeholder — safe in dev builds.
VITE_ADMOB_REWARDED_OFFLINE_BOOST_ANDROID=ca-app-pub-3940256099942544/5224354917
VITE_ADMOB_REWARDED_POST_DISCHARGE_ANDROID=ca-app-pub-3940256099942544/5224354917
VITE_ADMOB_REWARDED_MUTATION_REROLL_ANDROID=ca-app-pub-3940256099942544/5224354917
VITE_ADMOB_REWARDED_DECISION_RETRY_ANDROID=ca-app-pub-3940256099942544/5224354917
VITE_ADMOB_REWARDED_PIGGY_REFILL_ANDROID=ca-app-pub-3940256099942544/5224354917
VITE_ADMOB_REWARDED_STREAK_SAVE_ANDROID=ca-app-pub-3940256099942544/5224354917

VITE_ADMOB_REWARDED_OFFLINE_BOOST_IOS=ca-app-pub-3940256099942544/1712485313
VITE_ADMOB_REWARDED_POST_DISCHARGE_IOS=ca-app-pub-3940256099942544/1712485313
VITE_ADMOB_REWARDED_MUTATION_REROLL_IOS=ca-app-pub-3940256099942544/1712485313
